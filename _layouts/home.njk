---
layout: default
---
<div id="homepg-banner">
  <div id="homepg-banner-content">
    <h1>{{ heading }}</h1>
    <div id="practice-info-wrapper">
      <img id="logo" src="/images/logo.png" alt="logo" />
      <div id="practice-info" itemprop="description">
        <p id="practice-name">Family Medicine &amp; PA serving Bryan, College Station</p>
        <p>Caring for your family's needs from birth to geriatrics</p>
        <p>{{ providers }}</p>
      </div>
    </div>
    <div class="clearfix"></div>
    <a href="tel:+19796953570" id="header-phone-number" itemprop="telephone" title="Call to schedule an appointment">{{ phone }}</a>
  </div>
</div>
<div id="content" class="spanning">
  <div class="promo clearfix">
    <div class="wrap">
      <div class="promo-wrapper clearfix"></div>
      <div id="homepg-services" class="two columns">
        <div class="height-block">
          {{ services_body | markdownify | safe }}
        </div>
        <a href="/about/" class="button">{{ services_cta }}</a>
      </div>
      <div class="two columns">
        <div class="height-block">
          {{ patients_body | markdownify | safe }}
        </div>
        <a href="/patients/" class="button">{{ patients_cta }}</a>
      </div>
    </div>
  </div>
</div>
